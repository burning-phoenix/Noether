# Noether Configuration
# These are optional environment variables. The app prompts for the API key at startup.

# Fireworks AI API key (alternative to --api-key flag or interactive prompt)
# Get your key at: https://fireworks.ai/
# FIREWORKS_API_KEY=fw_...

# Local Qwen model path (optional, defaults to ./models/...)
# QWEN_MODEL_PATH=./models/Qwen3-Coder-30B-A3B-Instruct-Q4_K_M.gguf
